# 기본: 텍스트 파일은 LF로 통일
* text=auto eol=lf

# Windows 전용 스크립트는 CRLF 유지
*.ps1 text eol=crlf

# Shell 스크립트는 반드시 LF (Linux 실행용)
*.sh text eol=lf

# YAML, Python, Markdown은 LF
*.yaml text eol=lf
*.yml  text eol=lf
*.py   text eol=lf
*.md   text eol=lf

# 바이너리는 변환 없음
*.png  binary
*.jpg  binary
*.gif  binary
*.ico  binary
